{
  "name": "browser-game-translator",
  "version": "0.1.0",
  "private": true,
  "description": "Browser game localization",
  "main": "dist/main/main.js",
  "scripts": {
    "predev": "tsc -p tsconfig.main.json",
    "dev": "node scripts/dev.cjs",
    "build:icon": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/generate-icons.ps1",
    "build:launcher": "node scripts/build-launcher.cjs",
    "build": "tsc -p tsconfig.main.json && vite build",
    "package:dir": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false ELECTRON_CACHE=.cache/electron ELECTRON_BUILDER_CACHE=.cache/electron-builder electron-builder --win dir --x64",
    "package:velopack": "node scripts/package-velopack.cjs",
    "package:portable": "npm run build && npm run build:launcher && npm run package:dir && npm run package:velopack",
    "velopack:download:github": "vpk download github --outputDir release/velopack --repoUrl https://github.com/Heptagon196/BrowserGameTranslator",
    "velopack:upload:github": "vpk upload github --outputDir release/velopack --repoUrl https://github.com/Heptagon196/BrowserGameTranslator --merge",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.main.json",
    "lint": "eslint src --max-warnings 0",
    "check:unused": "tsc --noEmit -p tsconfig.unused.json",
    "start": "node scripts/start-electron.cjs"
  },
  "dependencies": {
    "@ag-ui/client": "^0.0.53",
    "@ag-ui/core": "^0.0.53",
    "@assistant-ui/react": "^0.14.0",
    "@assistant-ui/react-ag-ui": "^0.0.29",
    "@chenglou/pretext": "^0.0.6",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/language": "^6.12.3",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.42.1",
    "@floating-ui/react": "^0.27.19",
    "@mozilla/readability": "^0.6.0",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-virtual": "^3.13.24",
    "@vitejs/plugin-react": "^5.0.0",
    "7zip-min": "^3.0.1",
    "acorn": "^8.16.0",
    "cmdk": "^1.1.1",
    "font-list": "^2.0.2",
    "jsdom": "^29.1.1",
    "lucide-react": "^0.468.0",
    "open-websearch": "^2.1.10",
    "playwright-core": "^1.59.1",
    "react": "^18.3.1",
    "react-diff-viewer-continued": "^4.2.2",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.11.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2",
    "velopack": "^0.0.1589-ga2c5a97"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^20.17.10",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@types/turndown": "^5.0.6",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^42.0.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^6.0.5",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.browsergametranslator.app",
    "productName": "BrowserGameTranslator",
    "electronDist": "node_modules/electron/dist",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/velopack/lib/native/**/*"
    ],
    "extraResources": [
      {
        "from": "resources",
        "to": "resources"
      }
    ],
    "win": {
      "icon": "resources/icon/app.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "artifactName": "${productName}-${version}-${os}-${arch}-portable.${ext}"
  }
}
