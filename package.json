{
  "name": "browser-game-translator",
  "version": "0.1.0",
  "private": true,
  "description": "Desktop AI translation tool for offline browser games.",
  "main": "dist/main/main.js",
  "scripts": {
    "predev": "tsc -p tsconfig.main.json",
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && node scripts/start-electron.cjs --dev\"",
    "build:icon": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/generate-icons.ps1",
    "build:launcher": "node scripts/build-launcher.cjs",
    "build": "tsc -p tsconfig.main.json && vite build",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.main.json",
    "lint": "eslint src --max-warnings 0",
    "check:unused": "tsc --noEmit -p tsconfig.unused.json",
    "start": "node scripts/start-electron.cjs"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.6",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/language": "^6.12.3",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.42.1",
    "@floating-ui/react": "^0.27.19",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-virtual": "^3.13.24",
    "@vitejs/plugin-react": "^5.0.0",
    "7zip-min": "^3.0.1",
    "cmdk": "^1.1.1",
    "electron": "^42.0.0",
    "font-list": "^2.0.2",
    "itchio-downloader": "^1.2.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.17.10",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^6.0.5",
    "wait-on": "^8.0.1"
  }
}
